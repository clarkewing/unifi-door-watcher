# /etc/unifi-door-watcher/env  (chmod 0600, owner = unifi-door-watcher)
#
# Double-quote any value that contains $, `, \, &, or other shell
# metacharacters — Protect Alarm Manager webhook URLs frequently embed
# tokens with `$` and would otherwise be mangled by `set -a; source env`.
# systemd's EnvironmentFile reader is less aggressive about expansion but
# matching the safest form here keeps the file usable from a shell too.

ACCESS_TOKEN="replace-with-access-developer-api-token"
PROTECT_TOKEN="replace-with-protect-integration-api-token"
PROTECT_UNAUTH_URL="https://protect.example.lan/proxy/protect/integration/v1/alarm-manager/webhook/REPLACE"
PROTECT_HELD_URL="https://protect.example.lan/proxy/protect/integration/v1/alarm-manager/webhook/REPLACE"

# Only needed for `scripts/bootstrap_protect_alarms.py`. A dedicated local
# Protect user (Protect → Users → Add User → Local Access) with permission
# to manage automations.
PROTECT_USERNAME="door-watcher-bot"
PROTECT_PASSWORD="replace-with-strong-password"
