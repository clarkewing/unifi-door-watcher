# /etc/unifi-door-watcher/env  (chmod 640, owner = root, group = unifi-door-watcher)
#
# Double-quote any value that contains $, `, \, &, or other shell
# metacharacters — Protect Alarm Manager webhook URLs frequently embed
# tokens with `$` and would otherwise be mangled by `set -a; source env`.
# systemd's EnvironmentFile reader is less aggressive about expansion but
# matching the safest form here keeps the file usable from a shell too.

# --- runtime credentials (always required) ---
# Used by the watcher service on every ws connect, reconciliation poll,
# and outbound alarm-trigger POST. Restart the service after rotating.
ACCESS_TOKEN="replace-with-access-developer-api-token"
PROTECT_TOKEN="replace-with-protect-integration-api-token"

# --- bootstrap credentials (only needed if you run bootstrap scripts here) ---
# A dedicated local Protect user (Protect → Users → Add User → Local
# Access) with permission to manage automations. Only consumed by
# `scripts/bootstrap_protect_alarms.py`; the runtime service ignores
# them. Handy to keep on the host so `bootstrap_doors` and
# `bootstrap_protect_alarms` can be run over SSH when doors are added
# or renamed. Leave them out on hosts that will never bootstrap — the
# service will start regardless.
PROTECT_USERNAME="door-watcher-bot"
PROTECT_PASSWORD="replace-with-strong-password"
